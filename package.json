{
	"name": "pi-dynamic-workflow-extension",
	"version": "0.1.17",
	"description": "Pi extension that runs dynamic JavaScript workflows with isolated subagents and live progress rendering.",
	"keywords": [
		"agents",
		"pi",
		"pi-package",
		"subagents",
		"workflow"
	],
	"license": "MIT",
	"files": [
		"dist",
		"extensions",
		"src",
		"types",
		"README.md"
	],
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		},
		"./workflow": {
			"types": "./types/workflow.d.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"format": "vp fmt --write",
		"check": "vp check && tsc -p tsconfig.json --noEmit",
		"test:unit": "vitest --run tests/*.test.ts",
		"test:e2e": "vitest --run tests/e2e/*.test.ts",
		"test:e2e:live": "PI_E2E_LIVE=1 vitest --run tests/e2e/*.live.test.ts",
		"test": "npm run check && npm run build && vitest --run",
		"test:suite": "vitest --run tests/suite/*.test.ts tests/suite/regressions/*.test.ts"
	},
	"dependencies": {
		"acorn": "^8.16.0"
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@earendil-works/pi-tui": "^0.78.0",
		"@types/node": "^24.0.0",
		"typebox": "*",
		"typescript": "^5.9.3",
		"vite-plus": "^0.1.24",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@earendil-works/pi-tui": "^0.78.0",
		"typebox": "*"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"pi": {
		"extensions": [
			"extensions/workflow.ts"
		]
	}
}

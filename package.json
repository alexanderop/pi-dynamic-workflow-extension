{
  "name": "pi-dynamic-workflow-extension",
  "version": "0.1.0",
  "description": "A Pi package for Claude-Code-like dynamic workflows.",
  "keywords": [
    "pi-extension",
    "pi-package",
    "workflows"
  ],
  "homepage": "https://github.com/alexanderopalic/pi-dynamic-workflow-extension#readme",
  "bugs": {
    "url": "https://github.com/alexanderopalic/pi-dynamic-workflow-extension/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexanderopalic/pi-dynamic-workflow-extension.git"
  },
  "files": [
    "src",
    "types",
    "skills"
  ],
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    "./workflow": {
      "types": "./types/workflow.d.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit && tsc --noEmit -p types",
    "dup": "jscpd src --min-lines 10 --min-tokens 80 --threshold 1 --reporters console --noTips",
    "fmt": "oxfmt package.json tsconfig.json vitest.config.ts .oxlintrc.json .oxfmtrc.json src test tools",
    "fmt:check": "oxfmt --check package.json tsconfig.json vitest.config.ts .oxlintrc.json .oxfmtrc.json src test tools",
    "lint": "oxlint src test tools",
    "lint:fix": "oxlint --fix src test tools",
    "pi": "pi --no-extensions -e .",
    "release:major": "node tools/git-tag-release.mjs major",
    "release:minor": "node tools/git-tag-release.mjs minor",
    "release:patch": "node tools/git-tag-release.mjs patch",
    "release:version": "node tools/git-tag-release.mjs",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "verify": "pnpm run check && pnpm run lint && pnpm run fmt:check && pnpm test"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.7",
    "fast-check": "^4.8.0",
    "jscpd": "^4.2.4",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}

{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": ["node_modules/**", "repos/**", ".pnpm-store/**", ".pi/workflows/wf_*/**"],
  "jsPlugins": ["./tools/oxlint-plugin-local.js"],
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "local/test-name-should": "error"
      }
    }
  ]
}

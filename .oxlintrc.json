{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": ["node_modules/**", "repos/**", ".pnpm-store/**", ".pi/workflows/wf_*/**"],
  "jsPlugins": ["./tools/oxlint-plugin-local.js"],
  "plugins": ["unicorn", "typescript", "oxc", "import", "promise", "node", "vitest"],
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "rules": {
        "import/no-relative-parent-imports": "error"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "local/test-name-should": "error"
      }
    }
  ],
  "rules": {
    "eqeqeq": "error",
    "no-implicit-coercion": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-throw-literal": "error",
    "no-var": "error",
    "prefer-const": "error",
    "typescript/no-explicit-any": "error"
  }
}

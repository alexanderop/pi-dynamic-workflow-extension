{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": ["node_modules/**", "repos/**", ".pnpm-store/**", ".pi/workflows/wf_*/**"],
  "jsPlugins": ["./tools/oxlint-plugin-local.js"],
  "plugins": ["unicorn", "typescript", "oxc", "import", "promise", "node", "vitest"],
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "rules": {
        "import/no-relative-parent-imports": "error"
      }
    },
    {
      "files": ["src/workflows/**/*.ts"],
      "rules": {
        "local/no-restricted-feature-imports": [
          "error",
          {
            "patterns": [
              {
                "pattern": "^#src/extension/",
                "message": "src/workflows (domain core) must not import from src/extension (outer layer); the allowed dependency direction is extension -> workflows."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "vitest/no-standalone-expect": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "local/test-name-should": "error",
        "vitest/no-standalone-expect": "error",
        "vitest/expect-expect": [
          "error",
          { "assertFunctionNames": ["expect", "expect*", "**.expect*", "**.should*"] }
        ]
      }
    }
  ],
  "rules": {
    "eqeqeq": "error",
    "no-implicit-coercion": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-throw-literal": "error",
    "no-var": "error",
    "prefer-const": "error",
    "typescript/no-explicit-any": "error"
  }
}
